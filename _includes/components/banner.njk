<div id="banner">
    <div class="marquee">
        <div class="marquee__track">
            {# First copy is the readable one for screen readers. #}
            <span class="marquee__text">{{ meta.banner | md | safe }}</span>
            {# Visual duplicates for the seamless scroll: hidden from SR via
               aria-hidden but left clickable (no inert). #}
            <span class="marquee__text" aria-hidden="true">{{ meta.banner | md | safe }}</span>
            <span class="marquee__text" aria-hidden="true">{{ meta.banner | md | safe }}</span>
            <span class="marquee__text" aria-hidden="true">{{ meta.banner | md | safe }}</span>
        </div>
    </div>
</div>
{# Marquee scroll is CSS-driven (see _banner.scss .marquee__track) — no JS,
   so it works on usesAnimations:false pages and respects reduced-motion. #}