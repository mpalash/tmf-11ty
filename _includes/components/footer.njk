<footer>
    <a href="#" id="back-to-top"><img eleventy:ignore src="/img/icon-arrow-up.svg" alt="Back to top" width="24" height="24" /></a>
    <div>
        <a href="/" class="home-link" aria-label="{{ meta.title }}, home" title="{{ meta.siteName }}">
            <img eleventy:ignore src="{{ meta.footerLogo.url }}" alt="{{ meta.footerLogo.caption }}" width="{{ meta.footerLogo.width }}" height="{{ meta.footerLogo.height }}" />
        </a>
        {% for e in meta.emails %}
            <a href="mailto:{{ e }}">{{ e }}</a>
        {% endfor %}
        {% for a in meta.addresses %}
            {{ a | md | safe }}
        {% endfor %}
    </div>
    <nav>
        <h2 class="visually-hidden">Footer navigation menu</h2>
        <ul class="nav">
            {% for l in meta.footerNavLinks %}
                {% include "components/headerFooterLinkButton.njk" %}
            {% endfor %}
        </ul>
    </nav>
    <nav>
        <h2 class="visually-hidden">Social media navigation menu</h2>
        <ul class="nav">
            {% for l in meta.socialMediaLinks %}
                {% include "components/headerFooterLinkButton.njk" %}
            {% endfor %}
        </ul>
    </nav>
    <div class="copyright">{{ meta.copyrightNotice | md | safe }}</div>
</footer>
{% js %}
(function() {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    btn.addEventListener('click', function(e) {
        e.preventDefault();
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
})();
{% endjs %}