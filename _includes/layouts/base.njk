<!doctype html>
<html lang="{{ meta.language }}">
	<head>
		{% include "components/head-seo.njk" %}
		<link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/lenis@1.3.17/dist/lenis.min.css" onload="this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lenis@1.3.17/dist/lenis.min.css"></noscript>
	</head>
	<body>
		<a href="#skip" class="visually-hidden">Skip to main content</a>

		{% include "components/banner.njk" %}
		{% include "components/header.njk" %}

		<main id="skip">
			{{ content | safe }}
			{# {% include "components/test-markup.njk" %} #}
		</main>

		{% include "components/footer.njk" %}

		<!-- This page `{{ page.url | htmlBaseUrl }}` was built on {% currentBuildDate %} -->
		<script defer src="/js/heroReveal.js"></script>
		{% if usesAnimations != false %}
		<script defer src="https://cdn.jsdelivr.net/npm/lenis@1.3.17/dist/lenis.min.js"></script>
		<script defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js"></script>
		<script defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/ScrollTrigger.min.js"></script>
		<script defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/SplitText.min.js"></script>
		<script defer src="/js/smoothScroll.js"></script>
		<script defer src="/js/bgColorTransitionSmooth.js"></script>
		<script defer src="/js/headingAnimations-v2.js"></script>
		<script defer src="/js/imgReveal.js"></script>
		<script defer src="/js/columnScrollAnimation.js"></script>
		{% endif %}

		<!-- Per-page bundled scripts: placed after the deferred GSAP/animation
		     scripts so GSAP is guaranteed available when the module executes. -->
		<script type="module" src="{% getBundleFileUrl "js" %}"></script>

		{% if page.url == '/search/' %}
			<script>
				const searchIndexPromise = fetch('/search-index.json')
					.then(response => response.json());
			</script>
		{% endif %}

		<script>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());
		  gtag('config', 'G-7RRZHZW6MG');
		</script>
		<script defer src="https://www.googletagmanager.com/gtag/js?id=G-7RRZHZW6MG"></script>
	</body>
</html>