---
layout: layouts/base.njk
permalink: /search/
title: Search
excludeFromSearch: true
usesAnimations: false
---

<div class="search-container">
    <div class="search-input-wrapper">
        <h2>Search</h2>
        <label for="search-input" class="visually-hidden">Search the site</label>
        <input type="text" id="search-input" placeholder="What are you looking for?">
        <button type="button" id="clear-search" aria-label="Clear search">
            <img eleventy:ignore class="icon close" src="/img/icon-close.svg" alt="Clear search" width="24" height="24" />
        </button>
    </div>
    <div id="search-results"></div>
</div>

{% js %}
// Incremental site search powered by Pagefind (index built at /pagefind/).
(function() {
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const clearButton = document.getElementById('clear-search');
  if (!searchInput || !searchResults) return;

  let searchTimeout;
  let pagefindPromise = null;
  const MAX_RESULTS = 20;

  // Lazy-load and init Pagefind once.
  function loadPagefind() {
    if (!pagefindPromise) {
      pagefindPromise = import('/pagefind/pagefind.js')
        .then(async (pf) => { await pf.init(); return pf; })
        .catch((err) => { console.error('Failed to load Pagefind:', err); pagefindPromise = null; throw err; });
    }
    return pagefindPromise;
  }

  function getSearchParam() {
    return new URLSearchParams(window.location.search).get('q') || '';
  }

  function updateURL(query) {
    const url = new URL(window.location);
    if (query) url.searchParams.set('q', query);
    else url.searchParams.delete('q');
    window.history.replaceState({}, '', url);
  }

  function toggleClearButton() {
    clearButton.style.display = searchInput.value ? 'block' : 'none';
  }

  function clearSearch() {
    searchInput.value = '';
    searchResults.innerHTML = '';
    updateURL('');
    toggleClearButton();
    searchInput.focus();
  }

  function escapeHTML(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  async function performSearch(query) {
    if (query.length < 2) {
      searchResults.innerHTML = '';
      return;
    }
    try {
      const pf = await loadPagefind();
      const search = await pf.search(query);
      // Guard against a stale debounced response overwriting a newer query.
      if (searchInput.value.trim() !== query.trim()) return;
      const results = await Promise.all(
        search.results.slice(0, MAX_RESULTS).map((r) => r.data())
      );
      displayResults(results, query);
    } catch (err) {
      searchResults.innerHTML = '<p class="no-search-result">Search is unavailable right now.</p>';
    }
  }

  function displayResults(results, query) {
    if (results.length === 0) {
      searchResults.innerHTML = `<p class="no-search-result">No results found for “${escapeHTML(query)}”</p>`;
      return;
    }
    searchResults.innerHTML = results.map((r) => {
      const title = (r.meta && r.meta.title) ? escapeHTML(r.meta.title) : escapeHTML(r.url);
      // r.excerpt is sanitised HTML (with <mark> highlights) generated by Pagefind
      // from the site's own indexed content.
      return `
        <a href="${r.url}" class="search-result">
          <h3>${title}</h3>
          <p>${r.excerpt}</p>
          <span class="read-more badge">Read more</span>
        </a>`;
    }).join('');
  }

  // Init from URL, wire up events.
  const initialQuery = getSearchParam();
  searchInput.value = initialQuery;
  toggleClearButton();
  loadPagefind(); // warm the index
  if (initialQuery) performSearch(initialQuery);

  searchInput.addEventListener('input', function(e) {
    const query = e.target.value;
    toggleClearButton();
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      performSearch(query);
      updateURL(query);
    }, 150);
  });

  clearButton.addEventListener('click', clearSearch);

  searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') clearSearch();
  });

  window.addEventListener('popstate', function() {
    const query = getSearchParam();
    searchInput.value = query;
    toggleClearButton();
    performSearch(query);
  });
})();
{% endjs %}
