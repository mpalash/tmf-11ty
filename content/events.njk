---
pagination:
  data: events
  size: 1
  alias: event
permalink: "events/{{ event.title | slugify }}/index.html"
section: "event"
layout: layouts/base.njk
---
<article class="{{ section }} {{ event.title | slugify }}" data-pagefind-meta="title:{{ event.title }}">
    <section data-layout='hero'>
        {% set hero = event.hero %}
        {% include "components/hero.njk" %}
    </section>
    
    {% if event.details.length == 1 %}
        <ul class="all-event-details">
        {% for d in event.details %}
            <li class="solo" data-date-from="{{ d.dates.dateFrom }}"
                {% if d.dates.dateTo %}data-date-to="{{ d.dates.dateTo }}"{% endif %} >
                <a>
                    <div>
                        <h3>{{ d.eventName }}</h3>
                        <div class="badge-list">
                            {% for et in d.eventType %}
                                <span class="badge">{{ et }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    
                    {{ d.dates.dateFrom | formatEventDateTime(d.dates.dateTo) | safe }}
                    
                    <div>
                        <span class="event-venue">{{ d.venueName }}</span>
                        <span class="event-address">{{ d.venueAddress }}</span>
                    </div>
                </a>
            </li>
        {% endfor %}
        <ul>
    {% endif %}

    {% if event.details.length > 1 %}
        <ul class="all-event-details accordion">
        {% for d in event.details %}
            {% set detailIdx = loop.index %}
            <li class="accordion-item" data-date-from="{{ d.dates.dateFrom }}"
                {% if d.dates.dateTo %}data-date-to="{{ d.dates.dateTo }}"{% endif %} >
                <button type="button" class="accordion-header" aria-expanded="false" aria-controls="accordion-panel-{{ detailIdx }}">
                    <div>
                        <h3 class="accordion-title">{{ d.eventName }}</h3>
                        <div class="badge-list">
                            {% for et in d.eventType %}
                                <span class="badge">{{ et }}</span>
                            {% endfor %}
                        </div>
                    </div>

                    {{ d.dates.dateFrom | formatEventDateTime(d.dates.dateTo) | safe }}

                    <div>
                        <span class="event-venue">{{ d.venueName }}</span>
                        <span class="event-address">{{ d.venueAddress }}</span>
                    </div>
                    <div class="accordion-button" aria-hidden="true">
                        <img src="/img/expand.svg" alt="Expand" class="expand" eleventy:ignore width="64" height="64" />
                        <img src="/img/collapse.svg" alt="Collapse" class="collapse" eleventy:ignore width="64" height="64" />
                    </div>
                </button>
                <div class="accordion-content" id="accordion-panel-{{ detailIdx }}">
                    <div class="accordion-content-inner">
                        <section>
                            <div class="text-wrapper">
                                {{ d.eventDescription | md | safe }}
                            </div>
                        </section>
                        {% if d.gallery %}
                            <section class="gallery-wrapper">
                                <div class="gallery">
                                    <div class="gallery-videos">
                                        {% for video in d.gallery.videos %}
                                            <div class="youtube-embed" data-video-id="{{ video }}"></div>
                                        {% endfor %}
                                    </div>
                                    <div class="gallery-images">
                                        {% for i in d.gallery.images %}
                                            <a href="{{ i.url }}"
                                               class="lightbox"
                                               data-group="gallery-{{ detailIdx }}"
                                               data-caption="{{ i.caption }}"
                                               aria-label="View image: {{ i.caption }}">
                                                <img
                                                    src="{{ i.url }}"
                                                    alt="{{ i.caption }}" />
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            </section>
                        {% endif %}
                    </div>
                </div>
            </li>
        {% endfor %}
        </ul>
    {% endif %}
    
</article>
{% js %}
import Parvus from '/js/parvus.esm.min.js';
import { Accordion } from '/js/accordion.js';
import { YouTubeEmbed } from '/js/youtubeEmbed.js';

document.addEventListener('DOMContentLoaded', function() {
    if (document.querySelector('.lightbox')) {
        new Parvus();
    }
});

/* Accordion init (class in /js/accordion.js) */
document.addEventListener('DOMContentLoaded', () => {
    const accordionElement = document.querySelector('.accordion');
    if (!accordionElement) {
        return;
    }
    new Accordion(accordionElement, {
        duration: 0.5,
        ease: 'power2.inOut',
        openFirst: true
    });
});

/* YouTube embed init (class in /js/youtubeEmbed.js) */
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.youtube-embed').forEach(element => {
        new YouTubeEmbed(element);
    });
});

/* Image fade-in + caption rendering from alt text */
(function() {
    'use strict';

    function renderCaption(img) {
        const alt = img.getAttribute('alt');
        if (!alt || alt.trim() === '') {
            return;
        }
        const picture = img.closest('picture');
        if (!picture) {
            return;
        }
        const nextElement = picture.nextElementSibling;
        if (nextElement && nextElement.classList.contains('image-caption')) {
            return;
        }
        const caption = document.createElement('span');
        caption.classList.add('image-caption');
        caption.textContent = alt;
        picture.parentNode.insertBefore(caption, picture.nextSibling);
    }

    function fadeInImage(img) {
        if (img.hasAttribute('data-no-auto-fade')) {
            return;
        }
        img.classList.add('fade-in');
        renderCaption(img);

        if (img.complete && img.naturalHeight !== 0) {
            img.classList.add('loaded');
        } else {
            img.addEventListener('load', function() {
                img.classList.add('loaded');
            });
            img.addEventListener('error', function() {
                img.classList.add('loaded'); // Still fade in to show broken image
            });
        }
    }

    function init() {
        document.querySelectorAll('main picture img').forEach(function(img) {
            fadeInImage(img);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
{% endjs %}